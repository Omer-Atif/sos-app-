rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'approved', 'approvalsCount', 'createdAt'])
        && data.username is string && data.username.size() > 0 && data.username.size() <= 50
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.approved is bool
        && data.approvalsCount is int && data.approvalsCount >= 0
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // For the approver screen: list all pending users
      
      allow create: if isSignedIn() 
        && isOwner(userId)
        && isValidUser(incoming())
        && incoming().approved == false
        && incoming().approvalsCount == 0
        && incoming().createdAt == request.time;

      allow update: if isSignedIn()
        && (
          // Self update: can only change username? No, mostly immutable for this demo
          (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['username']))
          || 
          // Approval update: anyone else can approve (for the prototype)
          (!isOwner(userId) 
            && incoming().diff(existing()).affectedKeys().hasOnly(['approvalsCount', 'approved', 'approvers'])
            && incoming().approvalsCount == existing().approvalsCount + 1
            // Check if user already approved
            && !(request.auth.uid in existing().get('approvers', []))
            // Ensure approvers list is updated
            && incoming().approvers.hasAll(existing().get('approvers', []))
            && incoming().approvers.hasAll([request.auth.uid])
            // Logic for auto-approval
            && (incoming().approvalsCount >= 2 ? incoming().approved == true : incoming().approved == false)
          )
        );
    }

    // Alert validation
    function isValidAlert(data) {
      return data.keys().hasAll(['user', 'time', 'status', 'message'])
        && data.user is string && data.user.size() > 0
        && data.time is timestamp
        && data.status is string
        && data.message is string && data.message.size() <= 500;
    }

    match /alerts/{alertId} {
      allow create: if isSignedIn() && isValidAlert(incoming()) && incoming().time == request.time;
      allow read: if isSignedIn(); // Admins or users themselves
    }
  }
}
